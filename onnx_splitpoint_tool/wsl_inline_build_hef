#!/usr/bin/env python3
# -*- coding: utf-8 -*-

"""WSL/venv helper for building a HEF (translate + optimize + compile).

This file is intentionally shipped as an *extensionless* Python script because
the Windows->WSL bridge and the Linux "managed venv" backend both launch it via

    python <path-to-this-file> ...

The caller expects a single machine-readable line prefixed with the marker
``__SPLITPOINT_HAILO_RESULT__``.

Why this exists
---------------
The Hailo DFC (`hailo_sdk_client`) is a Linux-only Python wheel. Many users run
the GUI on Windows (calling into WSL2) or keep the DFC isolated in a dedicated
virtualenv. This helper lets the main tool stay independent of where the DFC is
installed.

Implementation notes
--------------------
The tool package is often *not* installed inside the DFC venv. Therefore this
script adds the repository root to ``sys.path`` so it can import
``onnx_splitpoint_tool`` directly from the checkout.
"""

from __future__ import annotations

import argparse
import base64
import json
import os
import sys
import time
from dataclasses import asdict
from pathlib import Path


RESULT_MARKER = "__SPLITPOINT_HAILO_RESULT__"


def _repo_root() -> Path:
    # <repo>/onnx_splitpoint_tool/wsl_inline_build_hef -> parents[1] == <repo>
    return Path(__file__).resolve().parents[1]


def main() -> int:
    ap = argparse.ArgumentParser(add_help=True)
    ap.add_argument("--onnx", required=True, help="Path to ONNX model")
    ap.add_argument("--hw-arch", default="hailo8")
    ap.add_argument("--net-name", default=None)
    ap.add_argument("--outdir", default=None)

    ap.add_argument("--fixup", default="1", choices=["0", "1"], help="Apply ONNX fixups")
    ap.add_argument("--add-conv-defaults", default="1", choices=["0", "1"], help="Add Conv defaults during fixup")
    ap.add_argument(
        "--disable-rt-metadata-extraction",
        default="1",
        choices=["0", "1"],
        help="Pass disable_rt_metadata_extraction to DFC translate",
    )

    ap.add_argument("--opt-level", type=int, default=1)
    ap.add_argument("--calib-dir", default=None)
    ap.add_argument("--calib-count", type=int, default=64)
    ap.add_argument("--calib-batch-size", type=int, default=8)
    ap.add_argument("--activation-part1-onnx", default=None, help="Optional Part1 ONNX used to generate activation calibration for multi-input Part2 models")
    ap.add_argument("--activation-gen-batch", type=int, default=8, help="Batch size when running Part1 to generate activation calibration")
    ap.add_argument("--force", default="0", choices=["0", "1"], help="Overwrite compiled.hef if it exists")
    ap.add_argument("--keep-artifacts", default="0", choices=["0", "1"], help="Save parsed/quantized HAR")
    ap.add_argument("--extra-model-script-b64", default=None, help="Optional base64-encoded Hailo model script appended before compile")
    args = ap.parse_args()

    # Ensure we can import the tool package even if it isn't installed in the venv.
    root = _repo_root()
    if str(root) not in sys.path:
        sys.path.insert(0, str(root))

    # Auto-select GPU vs CPU for the Hailo DFC.
    #
    # GPU acceleration requires an NVIDIA GPU *and* a CUDA toolkit that
    # includes nvvm/libdevice. If only a driver is present, TensorFlow/XLA
    # typically fails with "libdevice not found".
    #
    # Behaviour:
    # - If the user set CUDA_VISIBLE_DEVICES -> respect it.
    # - Else: use GPU when it looks usable, otherwise force CPU.
    from onnx_splitpoint_tool.cuda_probe import auto_configure_cuda  # local import

    cuda_info = auto_configure_cuda(prefer_gpu=True)
    try:
        # Keep it one line, human-readable. Marker JSON is printed later.
        print(f"[splitpoint][cuda] {cuda_info.get('summary') or ''}".rstrip(), flush=True)
    except Exception:
        pass

    from onnx_splitpoint_tool.hailo_backend import hailo_build_hef  # local import

    t0 = time.time()
    onnx_path = Path(args.onnx)
    outdir = Path(args.outdir) if args.outdir else None
    net_name = args.net_name or onnx_path.stem

    extra_model_script = None
    if args.extra_model_script_b64:
        try:
            extra_model_script = base64.b64decode(str(args.extra_model_script_b64).encode('ascii')).decode('utf-8')
        except Exception as exc:
            payload = {
                'ok': False,
                'elapsed_s': float(time.time() - t0),
                'hw_arch': str(args.hw_arch),
                'net_name': str(net_name),
                'backend': str(os.environ.get('ONNX_SPLITPOINT_HAILO_HELPER_BACKEND') or 'wsl'),
                'error': f'Invalid --extra-model-script-b64: {type(exc).__name__}: {exc}',
                'returncode': 2,
            }
            print(RESULT_MARKER + json.dumps(payload, ensure_ascii=False), flush=True)
            return 2

    res = hailo_build_hef(
        onnx_path,
        hw_arch=str(args.hw_arch),
        net_name=str(net_name),
        outdir=str(outdir) if outdir is not None else None,
        fixup=(args.fixup == "1"),
        add_conv_defaults=(args.add_conv_defaults == "1"),
        disable_rt_metadata_extraction=(args.disable_rt_metadata_extraction == "1"),
        opt_level=int(args.opt_level),
        calib_dir=str(args.calib_dir) if args.calib_dir else None,
        calib_count=int(args.calib_count),
        calib_batch_size=int(args.calib_batch_size),
        activation_part1_onnx=str(args.activation_part1_onnx) if args.activation_part1_onnx else None,
        activation_gen_batch=int(args.activation_gen_batch),
        force=(args.force == "1"),
        keep_artifacts=(args.keep_artifacts == "1"),
        extra_model_script=extra_model_script,
    )

    payload = asdict(res)
    payload["elapsed_s"] = float(payload.get("elapsed_s") or (time.time() - t0))
    # The compilation happens *inside* WSL/venv, even though the inner function
    # may label it as "local".
    payload["backend"] = str(os.environ.get("ONNX_SPLITPOINT_HAILO_HELPER_BACKEND") or "wsl")

    # Attach CUDA probe info so the GUI can surface the chosen compute mode.
    try:
        payload["cuda_probe"] = cuda_info
    except Exception:
        pass

    # Persist the payload next to the build outputs for easier debugging.
    try:
        outdir_eff = Path(args.outdir) if args.outdir else onnx_path.parent
        outdir_eff.mkdir(parents=True, exist_ok=True)
        p_json = outdir_eff / "hailo_hef_build_result.json"
        p_json.write_text(json.dumps(payload, ensure_ascii=False, indent=2), encoding="utf-8")
        payload["result_json_path"] = str(p_json)
    except Exception:
        pass

    print(RESULT_MARKER + json.dumps(payload, ensure_ascii=False), flush=True)
    return 0 if bool(payload.get("ok")) else 3


if __name__ == "__main__":
    raise SystemExit(main())
